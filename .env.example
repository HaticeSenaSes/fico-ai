# Bu dosya örnek şablondur. Gerçek değerleri fico-backend/.env içine yazın, asla commit etmeyin.

# Backend - Veritabanı
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Backend - JWT
JWT_SECRET=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Backend - AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Mobile - API URL (services/api.ts içinde)
# EXPO_PUBLIC_API_URL=https://fico-backend-api-production.up.railway.app/api/v1
